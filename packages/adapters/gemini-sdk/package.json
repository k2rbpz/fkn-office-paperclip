{
    "name": "@paperclipai/adapter-gemini-sdk",
    "version": "0.2.5",
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./server": "./src/server/index.ts"
    },
    "publishConfig": {
        "access": "public",
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js"
            },
            "./server": {
                "types": "./dist/server/index.d.ts",
                "import": "./dist/server/index.js"
            }
        },
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@paperclipai/adapter-utils": "workspace:*",
        "@google/generative-ai": "^0.22.0"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "typescript": "^5.7.3"
    }
}